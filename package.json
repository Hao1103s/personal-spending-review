{
  "name": "personal-spending-review",
  "version": "0.1.0",
  "private": true,
  "description": "Personal spending review desktop app built with Next.js, Prisma, SQLite, and Electron.",
  "author": "qiuwenhao",
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:reset": "prisma db push --force-reset && prisma db seed",
    "desktop:dev": "concurrently -k \"npm:dev\" \"npm:desktop:dev:electron\"",
    "desktop:dev:electron": "wait-on tcp:3000 && cross-env ELECTRON_START_URL=http://127.0.0.1:3000 electron .",
    "desktop:build:runtime": "npm run build && node scripts/prepare-desktop-runtime.mjs",
    "desktop:dist": "npm run desktop:build:runtime && electron-builder",
    "desktop:dist:mac": "npm run desktop:build:runtime && electron-builder --mac",
    "desktop:dist:win": "npm run desktop:build:runtime && electron-builder --win --x64",
    "desktop:dist:all": "npm run desktop:dist:mac && npm run desktop:dist:win"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.451.0",
    "next": "^15.0.0",
    "papaparse": "^5.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.8.1",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.13.0",
    "eslint-config-next": "^15.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^2.1.3",
    "wait-on": "^8.0.1"
  }
}
